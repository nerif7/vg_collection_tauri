# Copy file ini ke .env dan isi dengan nilai yang sesuai
# .env tidak di-commit ke git — .env.example ini yang di-commit sebagai template

# URL Cloudflare Worker yang sudah di-deploy
VITE_WORKER_URL=https://vg-collection-sync.YOUR_SUBDOMAIN.workers.dev

# Google OAuth 2.0 Client ID (dari Google Cloud Console → Credentials → Desktop app)
VITE_GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
